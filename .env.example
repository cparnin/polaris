# Copy to .env and fill in. .env is git-ignored - never commit real values.

# --- Server ---
# Bind address. Keep loopback unless you've put authentication in front of Polaris.
HOST=127.0.0.1
PORT=4000
# How often to auto-scan the network, in milliseconds (default 5 min). Lower
# values scan more often but use more CPU/network; 60000 = every minute.
# Validated: must be between 10000 and 2147483647. Anything else (including a
# stray comment or typo) is ignored with a warning rather than silently
# becoming a 1ms interval that scans back-to-back forever.
SCAN_INTERVAL_MS=300000
# Re-resolve every device's name (not just unknowns) once every Nth scan, so
# renamed / newly-woken devices refresh. Higher = cheaper but staler names.
NAME_REFRESH_EVERY=6
# Max rows kept in the activity log; older events are pruned each scan.
EVENT_RETENTION=5000

# --- ntfy push notifications (optional) ---
# Full topic URL. Use a LONG, UNGUESSABLE topic - anyone who knows a public
# ntfy.sh topic can read your alerts. Leave unset to disable notifications.
# NTFY_URL=https://ntfy.sh/polaris-home-CHANGE-ME-8fk39dk2mx7
# Optional bearer token for protected or self-hosted ntfy servers.
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxx
# Optional default priority: min | low | default | high | urgent
# NTFY_PRIORITY=high

# Label for the upstream node on the network map (your ISP), e.g. Frontier.
# ISP_NAME=Frontier

# --- Port scanning (needs `brew install nmap`) ---
# Port-scan devices automatically the first time they appear, and fold the
# result into the ntfy alert. Set to 0 to only ever scan on demand.
# AUTOSCAN_NEW_DEVICES=1
# Cap how many devices get auto-scanned in a single scan cycle.
# AUTOSCAN_MAX_PER_SCAN=3

# --- Advanced ---
# Extra Host header values allowed through the loopback guard. Only needed if
# you deliberately run Polaris off-loopback behind your own authentication.
# ALLOWED_HOSTS=polaris.lan
# Where the SQLite database lives (default ./data).
# POLARIS_DATA_DIR=./data
# Load a different env file instead of ./.env.
# POLARIS_ENV_FILE=./.env
# LaunchAgent label the ⏻ Quit button boots out.
# POLARIS_LAUNCHD_LABEL=com.polaris.dashboard
