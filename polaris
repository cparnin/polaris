#!/bin/bash
# polaris - the switch. Run it from the repo root:
#
#   ./polaris          # is it running?
#   ./polaris start
#   ./polaris stop     # stays off until you start it (or next login)
#   ./polaris restart  # pick up code changes
#   ./polaris rebuild  # npm run build, then restart
#   ./polaris logs     # tail the log
#   ./polaris open     # open the dashboard
#
#   ./polaris install    # set up auto-start at login (run once)
#   ./polaris uninstall  # remove it entirely
#
# Polaris runs as a macOS LaunchAgent. This is the only file you need; it exists
# so you never have to type `launchctl bootout gui/501/com.polaris...`.
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LABEL="com.polaris.dashboard"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG="$HOME/Library/Logs/polaris-dashboard.log"
TARGET="gui/$(id -u)/$LABEL"
URL="http://127.0.0.1:4000"

serving() { curl -sf -o /dev/null --max-time 3 "$URL/api/health"; }
loaded() { launchctl print "$TARGET" >/dev/null 2>&1; }

# `launchctl bootout` returns before the job is actually gone, so bootstrapping
# straight afterwards fails with "Bootstrap failed: 5: Input/output error".
wait_unloaded() {
  for _ in $(seq 1 20); do
    loaded || return 0
    sleep 0.5
  done
  return 1
}

# launchctl returns before the server is listening, so wait for a real response.
wait_ready() {
  echo -n "$1 Polaris"
  for _ in $(seq 1 30); do
    sleep 1; echo -n "."
    if serving; then echo " ready → $URL"; return 0; fi
  done
  echo " (no answer yet - check: ./polaris logs)"
}

case "${1:-status}" in
  status|"")
    if serving; then echo "Polaris: RUNNING → $URL"
    elif loaded; then
      echo "Polaris: loaded but not answering (check: ./polaris logs)"
    else echo "Polaris: STOPPED  (start it with: ./polaris start)"; fi
    ;;

  start)
    if serving; then echo "Polaris is already running → $URL"; exit 0; fi
    [ -f "$PLIST" ] || { echo "Not installed yet. Run: ./polaris install"; exit 1; }
    launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null
    wait_ready "Starting"
    ;;

  stop)
    launchctl bootout "$TARGET" 2>/dev/null
    wait_unloaded
    echo "Polaris stopped. It stays off until you run: ./polaris start"
    echo "(It also comes back on its own at your next login.)"
    ;;

  restart)
    launchctl kickstart -k "$TARGET" 2>/dev/null || { exec "$0" start; }
    wait_ready "Restarting"
    ;;

  rebuild)
    (cd "$ROOT" && npm run build) || exit 1
    exec "$0" restart
    ;;

  logs) echo "Tailing $LOG  (ctrl-C to quit)"; exec tail -f "$LOG" ;;
  open) exec open "$URL" ;;

  install)
    # Writes the LaunchAgent so Polaris starts at login and restarts if it
    # crashes. Paths are derived from this repo and $HOME - nothing hardcoded.
    mkdir -p "$HOME/Library/LaunchAgents" "$HOME/Library/Logs"
    cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>$ROOT/scripts/polaris-start.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>$ROOT</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>ProcessType</key>
    <string>Background</string>
    <key>StandardOutPath</key>
    <string>$LOG</string>
    <key>StandardErrorPath</key>
    <string>$HOME/Library/Logs/polaris-dashboard.err.log</string>
</dict>
</plist>
EOF
    launchctl bootout "$TARGET" 2>/dev/null
    wait_unloaded || { echo "Previous instance won't unload; try again."; exit 1; }
    launchctl bootstrap "gui/$(id -u)" "$PLIST" || exit 1
    launchctl kickstart -k "$TARGET" >/dev/null 2>&1
    wait_ready "Installing -"
    echo "  Auto-starts at login. Logs: $LOG"
    echo "  Remove it with: ./polaris uninstall"
    ;;

  uninstall)
    # Also boots out the pre-rename label, in case it's still lingering.
    for l in "$LABEL" com.iris.dashboard; do
      launchctl bootout "gui/$(id -u)/$l" 2>/dev/null
      rm -f "$HOME/Library/LaunchAgents/$l.plist"
    done
    wait_unloaded
    echo "Polaris auto-start removed, and any running instance stopped."
    echo "(Your device history in data/ is untouched.)"
    ;;

  -h|--help|help) sed -n '2,13p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//' ;;
  *)
    echo "usage: ./polaris {status|start|stop|restart|rebuild|logs|open|install|uninstall}" >&2
    exit 2
    ;;
esac
